rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════
// FlockChat — Firestore Security Rules (Standalone)
//
// This is the STANDALONE FlockChat deployment (flockos-comms.web.app).
// Contains ONLY FlockChat-specific collections:
//   - conversations (DMs, rooms, channels) + messages + typing
//   - notifications
//   - settings (VAPID keys, notification preferences)
//   - users (FCM tokens, basic profile)
//   - permissions (role-based access control)
//   - templates (message templates)
//   - broadcasts (announcements)
//
// Deploy via:
//   firebase deploy --only firestore:rules --project flockos-comms
//
// SOURCE DOCUMENT: Architechtural Docs/New Covenant/Architecture/B-Master FlockChat.md
// ═══════════════════════════════════════════════════════════════════════

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function userRole() {
      // Check Firestore permissions collection (source of truth for roles)
      // Returns null if no permissions doc exists (user defaults to member)
      let permPath = /databases/$(database)/documents/permissions/$(userEmail());
      return exists(permPath) ? get(permPath).data.role : null;
    }

    function isPastorOrAdmin() {
      // Check if permissions doc exists and has pastor/admin/seed role
      let role = userRole();
      return role != null && role in ['pastor', 'admin', 'seed'];
    }

    function isLeaderOrAbove() {
      let role = userRole();
      return role != null && role in ['leader', 'pastor', 'admin', 'seed'];
    }

    // ── Conversations (DMs, Rooms, Threads, Channels) ───────────────
      match /conversations/{convoId} {

        // LIST: allow queries for any signed-in user (client-side filters by participant/type)
        allow list: if isSignedIn();

        // GET: participant/subscriber, creator, or room/channel (browsable)
        // resource == null guard: allows get() on non-existent docs (e.g. DM
        // existence check in createDM) — there is no data to protect.
        allow get: if isSignedIn() && (
          resource == null
          || resource.data.type == 'room'
          || resource.data.type == 'channel'
          || userEmail() in resource.data.participants
          || userEmail() in resource.data.subscribers
          || resource.data.createdBy == userEmail()
        );

        // CREATE: any church member can start a conversation
        allow create: if isSignedIn();

        // UPDATE: participants, subscribers, creator, or pastor/admin
        allow update: if isSignedIn() && (
          userEmail() in resource.data.participants
          || userEmail() in resource.data.subscribers
          || resource.data.createdBy == userEmail()
          || isPastorOrAdmin()
        );

        // DELETE: creator or pastor/admin only
        allow delete: if isSignedIn() && (
          resource.data.createdBy == userEmail()
          || isPastorOrAdmin()
        );

        // ── Messages sub-collection ─────────────────────────────────
        match /messages/{msgId} {
          // Read: any church member (they already navigated to the convo)
          allow read: if isSignedIn();

          // Create: any church member
          allow create: if isSignedIn();

          // Update: sender or pastor/admin
          allow update: if isSignedIn() && (
            resource.data.senderEmail == userEmail()
            || isPastorOrAdmin()
          );

          // Delete: sender or pastor/admin
          allow delete: if isSignedIn() && (
            resource.data.senderEmail == userEmail()
            || isPastorOrAdmin()
          );
        }

        // ── Typing indicators (ephemeral) ───────────────────────────
        match /typing/{userId} {
          allow read, write: if isSignedIn();
        }
      }

      // ── Notifications ─────────────────────────────────────────────────
      match /notifications/{notifId} {
        // Read own notifications
        allow read: if isSignedIn()
          && resource.data.recipientEmail == userEmail();

        // Create: any church member (system-generated via client or admin)
        allow create: if isSignedIn();

        // Update own (mark read)
        allow update: if isSignedIn()
          && resource.data.recipientEmail == userEmail();

        // Delete own
        allow delete: if isSignedIn()
          && (resource.data.recipientEmail == userEmail() || isPastorOrAdmin());
      }

      // ── App Settings ──────────────────────────────────────────────────
      match /settings/{settingId} {
        // Read: any member; Write app-level settings: pastor/admin only
        allow read: if isSignedIn();

        // notifPrefs_* docs are writeable by the owning user
        allow write: if isSignedIn() && (
          isPastorOrAdmin()
          || settingId.matches('notifPrefs_.*')
        );
      }

      // ── Templates ─────────────────────────────────────────────────────
      match /templates/{templateId} {
        // Read: any member
        allow read: if isSignedIn();

        // Create/Update: leader+ or pastor/admin
        allow create, update: if isSignedIn() && isLeaderOrAbove();

        // Delete: pastor/admin or creator
        allow delete: if isSignedIn() && (
          resource.data.createdBy == userEmail()
          || isPastorOrAdmin()
        );
      }

      // ── Broadcasts ────────────────────────────────────────────────────
      match /broadcasts/{broadcastId} {
        // Read: any member
        allow read: if isSignedIn();

        // Create: leader+ can send broadcasts
        allow create: if isSignedIn() && isLeaderOrAbove();

        // Update: only pastor/admin (adjust delivery stats, etc.)
        allow update: if isSignedIn() && isPastorOrAdmin();

        // Delete: pastor/admin only
        allow delete: if isSignedIn() && isPastorOrAdmin();
      }

      // ── Users (AuthUsers) ──────────────────────────────────────────
      match /users/{uid} {
        // Read own profile or pastor/admin can read all
        allow read: if isSignedIn() && (
          uid == request.auth.uid
          || isPastorOrAdmin()
        );

        // Create: any signed-in user can create their own profile
        allow create: if isSignedIn() && uid == request.auth.uid;

        // Update: own profile or pastor/admin
        allow update: if isSignedIn() && (
          uid == request.auth.uid
          || isPastorOrAdmin()
        );

        // Delete: pastor/admin only
        allow delete: if isSignedIn() && isPastorOrAdmin();
      }

      // ── Permissions ─────────────────────────────────────────────────
      match /permissions/{email} {
        // Read: own permissions or pastor/admin
        allow read: if isSignedIn() && (
          email == userEmail()
          || isPastorOrAdmin()
        );

        // Write: pastor/admin only
        allow write: if isSignedIn() && isPastorOrAdmin();
      }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
