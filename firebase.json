{
  "hosting": {
    "site": "flockos-comms",
    "public": "flockchat-public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      { "source": "**", "destination": "/FlockChat.html" }
    ]
  },
  "firestore": {
    "rules": "FlockChat.Firestore.Rules",
    "indexes": "flockchat-firestore.indexes.json"
  },
  "functions": [
    {
      "codebase": "default",
      "source": "functions",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    },
    {
      "codebase": "fcm",
      "source": "functions-fcm",
      "runtime": "nodejs20",
      "ignore": [
        "node_modules",
        ".git"
      ]
    }
  ]
}
